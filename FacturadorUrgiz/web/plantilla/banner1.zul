                    <menuitem label="Kardex detallado" id="btnKardex"  class=" menu_item" /> 
                    <menuitem label="Kardex general" id="btnKardexPorProd"  class="menu_item" />   
                    <menuitem label="Rotacion productos" id="btnRotacionProducto" class=" menu_item"/>
                    <menuitem label="Ajuste de Entrada/Salida" id="btnAjuste" class=" menu_item" />    
