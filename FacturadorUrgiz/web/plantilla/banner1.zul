


   <zk>

    <div class="banner" id="loginWin"  style="height:100vh; overflow:scroll"  width="100%"
         apply="com.ec.controlador.LogoutController" >
        <div class="menusuperior" style="background:#EDEDEE" >


            <div class="logo_defact" >
                <image style="margin:auto; display block;"  src="/imagenes/logo/paybillslogo.png" class="logo_defact" />                       
            </div>
            <div class=" " >
                <div class="usuario" apply="org.zkoss.bind.BindComposer" 
                     viewModel="@id('vm') @init('com.ec.controlador.MenuToolbar')">
                    <toolbar class="usuarioData" style="background:white;display:grid;" id="tb">
                     
                      
         
                        <label value="Hola, " if="${not sessionScope.userCredential.anonymous}" class="labelNuevo" />
                        <label value="${sessionScope.usuario.nombreUsuario} " class="labelNuevo" if="${not sessionScope.userCredential.anonymous}" />
                        <!--<label value="${sessionScope.usuario.nombreUsuario} / ${sessionScope.usuario.tipoambiente.codTipoambiente}" class="labelNuevo" if="${not sessionScope.userCredential.anonymous}" />-->
                       
                      
                           <div >
                        `<a sclass="logout labelLogout" id="logout" if="${not sessionScope.userCredential.anonymous}" class="form-group salir" >  
                        <div class="btnSalir">
                            <label  value="Salir " if="${not sessionScope.userCredential.anonymous}" sclass=" labelLogout"/> 
                            <div class="fa-solid fa-arrow-right-from-bracket icon_exit" />   
                        </div>                          
                    </a>             
                </div>

                
                       
                    </toolbar>
                </div>
               
            </div>
        </div>
        <div class="menuinferior">
            <div  viewModel="@id('vm')" id="gridMenu" 
                  apply="com.ec.controlador.MenuOpciones" 
